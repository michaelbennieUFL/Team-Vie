DJANGO_SECRET_KEY=replace-with-strong-secret
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173
DJANGO_SECURE_SSL_REDIRECT=true
DB_NAME=vie-db
DB_USER=vie
DB_PASSWORD=replace-with-strong-db-password
TASK_TIMER_SCORING_ENABLED=true
VITE_API_BASE_URL=/api
# protocol + host only (no trailing slash/path), e.g. wss://teamvie.michaelbennie.org
VITE_WS_BASE_URL=wss://teamvie.michaelbennie.org
